# ── Shopify Store ──────────────────────────────────────────────────────────────
SHOPIFY_SHOP=oscarslab.myshopify.com

# Admin API – use EITHER (A) or (B):
# (A) Static token (legacy custom app or manual token):
#     SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxx
# (B) Dev Dashboard app – client credentials (token auto-fetched and refreshed):
#     SHOPIFY_CLIENT_ID=your_client_id
#     SHOPIFY_CLIENT_SECRET=your_client_secret
# Scopes: read_orders, write_orders, read_products, write_products,
#         read_customers, write_customers, read_inventory, write_inventory
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-01

# Storefront API – create a Storefront token in the store Headless channel
SHOPIFY_STOREFRONT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret – from the webhook registration response (or Partners Dashboard)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite path for local dev; swap for Postgres URL in prod
DATABASE_URL=./data/also.db
# POSTGRES_URL=postgresql://user:pass@localhost:5432/also_db

# ── AWS (for real EventBridge/SQS integration – bonus) ─────────────────────────
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# EVENTBRIDGE_BUS_ARN=arn:aws:events:us-west-2:123456789:event-bus/also-bus
# SQS_ORDER_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789/also-orders
