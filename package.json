{
  "name": "shopify-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/storefront"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/backend\" \"npm run dev -w apps/storefront\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:storefront": "npm run dev -w apps/storefront",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
